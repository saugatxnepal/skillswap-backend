datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  Admin
  Mentor
  Learner
}

enum SessionStatus {
  PENDING_MATCH
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REPORTED
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum ReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum ReportReason {
  INAPPROPRIATE_BEHAVIOR
  TECHNICAL_ISSUES
  NO_SHOW
  HARASSMENT
  SPAM
  OTHER
}

model User {
  UserID               String     @id @default(uuid())
  FullName             String
  Email                String     @unique
  PasswordHash         String
  Role                 Role       @default(Learner)
  Bio                  String?
  ProfileImageURL      String?
  CreatedAt            DateTime   @default(now())
  PasswordResetToken   String?
  PasswordResetExpires DateTime?
  
  // Relations
  mentorSkills         UserSkill[]
  learnerSessions      Session[]   @relation("LearnerSessions")
  mentorSessions       Session[]   @relation("MentorSessions")
  sentMessages         Message[]   @relation("SentMessages")
  availability         Availability[] @relation("UserAvailability")
  mentorReviews        Review[]    @relation("MentorReviews")
  learnerReviews       Review[]    @relation("LearnerReviews")
  reportsMade          Report[]    @relation("ReportsMade")
  reportsReceived      Report[]    @relation("ReportsReceived")
  sessionParticipants  SessionParticipant[] @relation("ParticipantSessions")
  timeSlots            TimeSlot[]  @relation("UserTimeSlots")
  notifications        Notification[] @relation("UserNotifications")
  webRTCLogs           WebRTCLog[] @relation("UserWebRTCLogs")
  adminActions         AdminAction[] @relation("AdminActions")
  targetedByActions    AdminAction[] @relation("TargetedUserActions")
  sessionMonitoringLogs SessionMonitoringLog[] @relation("AdminMonitoringLogs")
}

model Skill {
  SkillID          String         @id @default(uuid())
  Name             String
  Description      String?
  SkillCategoryID  String
  SkillCategory    SkillCategory  @relation(fields: [SkillCategoryID], references: [SkillCategoryID])
  
  // Relations
  userSkills       UserSkill[]
  sessionSkills    SessionSkill[]
}

model SkillCategory {
  SkillCategoryID String   @id @default(uuid())
  Name            String
  Description     String?
  
  // Relations
  Skills          Skill[]
}

model UserSkill {
  UserSkillID     String   @id @default(uuid())
  UserID          String
  User            User     @relation(fields: [UserID], references: [UserID])
  SkillID         String
  Skill           Skill    @relation(fields: [SkillID], references: [SkillID])
  IsMentor        Boolean  @default(false) // true if user wants to mentor this skill
  IsLearner       Boolean  @default(true)  // true if user wants to learn this skill
  ExperienceLevel Int?     // 1-5 scale
  CreatedAt       DateTime @default(now())
  
  @@unique([UserID, SkillID])
}

model Session {
  SessionID       String        @id @default(uuid())
  Title           String
  Description     String?
  LearnerID       String
  Learner         User          @relation("LearnerSessions", fields: [LearnerID], references: [UserID])
  MentorID        String?
  Mentor          User?         @relation("MentorSessions", fields: [MentorID], references: [UserID])
  Status          SessionStatus @default(PENDING_MATCH)
  ScheduledStart  DateTime?
  ScheduledEnd    DateTime?
  ActualStartTime DateTime?
  ActualEndTime   DateTime?
  MeetingLink     String?       // Google Meet link
  MeetingProvider String?       // e.g., "google_meet"
  CreatedAt       DateTime      @default(now())
  UpdatedAt       DateTime      @updatedAt
  
  // Relations
  messages        Message[]     @relation("SessionMessages")
  timeSlots       TimeSlot[]    @relation("SessionTimeSlots")
  reviews         Review[]      @relation("SessionReviews")
  skills          SessionSkill[]
  participants    SessionParticipant[] @relation("SessionParticipants")
  reports         Report[]      @relation("SessionReports")
  adminActions    AdminAction[] @relation("SessionAdminActions")
  webRTCLogs      WebRTCLog[]   @relation("SessionWebRTCLogs")
  monitoringLogs  SessionMonitoringLog[] @relation("SessionMonitoringLogs")
}

model SessionSkill {
  SessionSkillID String  @id @default(uuid())
  SessionID      String
  Session        Session @relation(fields: [SessionID], references: [SessionID])
  SkillID        String
  Skill          Skill   @relation(fields: [SkillID], references: [SkillID])
  
  @@unique([SessionID, SkillID])
}

model SessionParticipant {
  ParticipantID String   @id @default(uuid())
  SessionID     String
  Session       Session  @relation("SessionParticipants", fields: [SessionID], references: [SessionID])
  UserID        String
  User          User     @relation("ParticipantSessions", fields: [UserID], references: [UserID])
  JoinedAt      DateTime?
  LeftAt        DateTime?
  IsAdminMonitor Boolean @default(false) // For admin monitoring
}

model TimeSlot {
  TimeSlotID    String   @id @default(uuid())
  SessionID     String
  Session       Session  @relation("SessionTimeSlots", fields: [SessionID], references: [SessionID])
  UserID        String
  User          User     @relation("UserTimeSlots", fields: [UserID], references: [UserID])
  StartTime     DateTime
  EndTime       DateTime
  IsAvailable   Boolean  @default(true)
  IsSelected    Boolean  @default(false) // When both agree on this slot
  CreatedAt     DateTime @default(now())
}

model Availability {
  AvailabilityID String   @id @default(uuid())
  UserID         String
  User           User     @relation("UserAvailability", fields: [UserID], references: [UserID])
  DayOfWeek      Int      // 0-6 (Sunday-Saturday)
  StartTime      String   // Format: "HH:MM"
  EndTime        String   // Format: "HH:MM"
  IsRecurring    Boolean  @default(true)
  SpecificDate   DateTime? // For one-time availability
  CreatedAt      DateTime @default(now())
}

model Message {
  MessageID     String      @id @default(uuid())
  SessionID     String
  Session       Session     @relation("SessionMessages", fields: [SessionID], references: [SessionID])
  SenderID      String
  Sender        User        @relation("SentMessages", fields: [SenderID], references: [UserID])
  Content       String
  MessageType   MessageType @default(TEXT)
  FileURL       String?
  ReadAt        DateTime?
  CreatedAt     DateTime    @default(now())
  UpdatedAt     DateTime    @updatedAt
  
  @@index([SessionID, CreatedAt])
}

model Review {
  ReviewID       String   @id @default(uuid())
  SessionID      String
  Session        Session  @relation("SessionReviews", fields: [SessionID], references: [SessionID])
  ReviewerID     String
  Reviewer       User     @relation("LearnerReviews", fields: [ReviewerID], references: [UserID])
  RevieweeID     String
  Reviewee       User     @relation("MentorReviews", fields: [RevieweeID], references: [UserID])
  Rating         Int      // 1-5 stars
  Comment        String?
  IsMentorReview Boolean  // true if reviewing mentor, false if reviewing learner
  CreatedAt      DateTime @default(now())
  
  @@unique([SessionID, ReviewerID, RevieweeID])
}

model Report {
  ReportID       String       @id @default(uuid())
  SessionID      String?
  Session        Session?     @relation("SessionReports", fields: [SessionID], references: [SessionID])
  ReporterID     String
  Reporter       User         @relation("ReportsMade", fields: [ReporterID], references: [UserID])
  ReportedUserID String
  ReportedUser   User         @relation("ReportsReceived", fields: [ReportedUserID], references: [UserID])
  Reason         ReportReason
  Description    String
  Status         ReportStatus @default(PENDING)
  AdminNotes     String?
  CreatedAt      DateTime     @default(now())
  ResolvedAt     DateTime?
}

model AdminAction {
  ActionID      String   @id @default(uuid())
  AdminID       String
  Admin         User     @relation("AdminActions", fields: [AdminID], references: [UserID])
  ActionType    String   // e.g., "WARNING", "SUSPENSION", "SESSION_MONITOR"
  TargetUserID  String?
  TargetUser    User?    @relation("TargetedUserActions", fields: [TargetUserID], references: [UserID])
  SessionID     String?
  Session       Session? @relation("SessionAdminActions", fields: [SessionID], references: [SessionID])
  Description   String
  CreatedAt     DateTime @default(now())
}

model Notification {
  NotificationID String   @id @default(uuid())
  UserID         String
  User           User     @relation("UserNotifications", fields: [UserID], references: [UserID])
  Type           String   // e.g., "SESSION_SCHEDULED", "NEW_MESSAGE", "MATCH_FOUND"
  Title          String
  Content        String
  IsRead         Boolean  @default(false)
  Data           Json?    // Additional data as JSON
  CreatedAt      DateTime @default(now())
}

// For WebRTC signaling and session monitoring
model WebRTCLog {
  LogID         String   @id @default(uuid())
  SessionID     String
  Session       Session  @relation("SessionWebRTCLogs", fields: [SessionID], references: [SessionID])
  UserID        String
  User          User     @relation("UserWebRTCLogs", fields: [UserID], references: [UserID])
  EventType     String   // e.g., "CONNECTION", "DISCONNECTION", "ICE_CANDIDATE", "OFFER", "ANSWER"
  Data          Json?    // WebRTC signaling data
  Timestamp     DateTime @default(now())
}

model SessionMonitoringLog {
  LogID         String   @id @default(uuid())
  SessionID     String
  Session       Session  @relation("SessionMonitoringLogs", fields: [SessionID], references: [SessionID])
  AdminID       String
  Admin         User     @relation("AdminMonitoringLogs", fields: [AdminID], references: [UserID])
  JoinedAt      DateTime
  LeftAt        DateTime?
  Notes         String?  // Admin notes during monitoring
}